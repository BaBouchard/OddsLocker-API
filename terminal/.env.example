# Terminal - central aggregator for scrapers
# Copy to .env and set as needed

# Port for HTTP (POST /ingest) and WebSocket (viewers). Railway sets PORT.
PORT=3000

# Optional: same value on scraper (TERMINAL_INGEST_SECRET) so only your VPS can POST /ingest.
# TERMINAL_INGEST_SECRET=

# Optional: password for viewing the terminal page + WebSocket (does not block /ingest).
# TERMINAL_LOGIN_PASSWORD=
