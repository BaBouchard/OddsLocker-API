# Live odds ingestion - config
# Copy to .env and set your values

# League to stream (one league for now). Examples: nba, nfl, mlb, nhl, soccer_england_league_one
LEAGUE_KEY=basketball_nba

# Sportsbook source: set to your sportsbook's WebSocket URL or leave empty to use poll adapter
# If your book has a WebSocket API for live odds, put the URL here.
SPORTSBOOK_WS_URL=

# If no WebSocket, we can poll a REST endpoint (optional). Set to full URL that returns live odds.
# SPORTSBOOK_NAME=betrivers_ny   (identifier in normalized output; default book1)
SPORTSBOOK_POLL_URL=

# Optional: template URL for per-event bet offers (used on "Fetch once").
# Use {eventId} where the event id should go.
# Example for BetRivers/Kambi:
# SPORTSBOOK_BET_TEMPLATE_URL=https://eu1.offering-api.kambicdn.com/offering/v2018/rsiusny/betoffer/event/{eventId}.json?lang=en_US&market=US-NY&client_id=200&channel_id=1&includeParticipants=true
SPORTSBOOK_BET_TEMPLATE_URL=

# Or: URL to the sportsbook's live page (we fetch the page and try to extract embedded odds/JSON).
# Best result if the site exposes an API: use DevTools → Network to find that URL and set SPORTSBOOK_POLL_URL instead.
SPORTSBOOK_SCRAPE_URL=

# Poll interval in ms when using polling (default 2000 = 2 seconds for high speed)
POLL_INTERVAL_MS=2000

# Optional: how many events to request detailed bet offers for when you click "Fetch once"
# MAX_DETAIL_EVENTS=3

# Optional: base URL for BetRivers (or other Kambi) deep links. Used for bookmaker_link on each outcome.
# Event page: {base}/{eventId}. Coupon (betslip): {base}/{eventId}?coupon=straight|{outcomeId}|
# BOOKMAKER_BASE_URL=https://ny.betrivers.com/?page=sportsbook#event/

# ---- Second sportsbook (same normalized format; set to enable multi-book merge) ----
# SPORTSBOOK_2_POLL_URL=https://eu1.offering-api.kambicdn.com/offering/v2018/.../event/live/open.json?...
# SPORTSBOOK_2_NAME=book2
# SPORTSBOOK_2_BET_TEMPLATE_URL=https://.../betoffer/event/{eventId}.json?...
# SPORTSBOOK_2_MAX_DETAIL_EVENTS=3
# SPORTSBOOK_2_BOOKMAKER_BASE_URL=https://....

# ---- FanDuel in-play API (enables FanDuel in multi-book + fetch checkboxes) ----
# FANDUEL_POLL_URL=https://api.sportsbook.fanduel.com/sbapi/in-play?timezone=America%2FNew_York&eventTypeId=7522&includeTabs=true&_ak=...
# FANDUEL_NAME=FanDuel
# Required. Copy from Request Headers: X-Sportsbook-Region (e.g. NJ, NY, PA).
# FANDUEL_REGION=NJ
# Sent as Referer/Origin so the API returns data (not empty). Use your state URL if different, e.g. https://sportsbook.nj.fanduel.com
# FANDUEL_ORIGIN=https://sportsbook.fanduel.com
# Optional: if API returns 502 from server but 200 in browser, copy Cookie header from DevTools (Request Headers) and set here. Cookies expire.
# FANDUEL_COOKIE=
# FANDUEL_BOOKMAKER_BASE_URL=https://sportsbook.fanduel.com
# Optional label only; if FanDuel JSON has no competition name, normalized league is always "Other" (never inferred from here).

# ---- Bovada live sportsbook API (enables Bovada in multi-book) ----
# Use the live events coupon URL; only events with "live": true are included.
# BOVADA_POLL_URL=https://www.bovada.lv/services/sports/event/coupon/events/A/description/?selectedPaths=...&marketFilterId=def&liveOnly=true&lnGrp=2&lang=en
# BOVADA_NAME=Bovada
# BOVADA_SPORT=basketball
# BOVADA_LEAGUE=Other
# BOVADA_BOOKMAKER_BASE_URL=https://www.bovada.lv

# ---- PointsBet in-play API (one URL per sport; enables PointsBet in multi-book) ----
# Set at least one to enable PointsBet. Scraper fetches each configured sport with a short stagger.
# POINTSBET_BASKETBALL_URL=https://api.on.pointsbet.com/api/v2/events/inplay/basketball
# POINTSBET_BASEBALL_URL=https://api.on.pointsbet.com/api/v2/events/inplay/baseball
# POINTSBET_SOCCER_URL=https://api.on.pointsbet.com/api/v2/events/inplay/soccer
# POINTSBET_FOOTBALL_URL=https://api.on.pointsbet.com/api/v2/events/inplay/football
# POINTSBET_TENNIS_URL=https://api.on.pointsbet.com/api/v2/events/inplay/tennis
# POINTSBET_NAME=PointsBet
# POINTSBET_BOOKMAKER_BASE_URL=https://www.pointsbet.com
# If you get 403, copy Cookie from DevTools (Request Headers when you load the API URL in browser) and set here. Cookie expires.
# POINTSBET_COOKIE=
# Set DEBUG_POINTSBET=1 to save first response to debug-pointsbet-response.json (compare with browser).
# If you get 403, try your state subdomain (e.g. api.nj.pointsbet.com) in the URLs above.

# ---- BetMGM live highlights API (enables BetMGM in multi-book; scrapes every market) ----
# Full URL including x-bwin-accessid and query params (state=Live, subdivision, etc.). Copy from browser Network tab.
# BETMGM_POLL_URL=https://www.ny.betmgm.com/cds-api/bettingoffer/live/highlights?x-bwin-accessid=...&lang=en-us&country=US&state=Live&...
# BETMGM_NAME=BetMGM
# BETMGM_BOOKMAKER_BASE_URL=https://www.ny.betmgm.com
# If you get 403: BetMGM (like PointsBet) is behind Cloudflare; Node fetch is blocked. Cookie/headers are not enough; need Playwright or browser context to fetch.
# BETMGM_COOKIE=

# ---- 888sport in-play API (getInplayEvents/all; multi-sport) ----
# Central multi-sport feed. Use DevTools → Network → spectate-web.888sport.com/spectate/inplay-req/getInplayEvents/all and copy as cURL.
# EIGHTS_POLL_URL=https://spectate-web.888sport.com/spectate/inplay-req/getInplayEvents/all
# EIGHTS_NAME=888sport
# EIGHTS_BOOKMAKER_BASE_URL=https://www.888sport.com
# EIGHTS_COOKIE=full Cookie header value from DevTools (Request Headers)

# Our WebSocket server port (clients connect here to receive live odds)
WS_SERVER_PORT=8765

# Optional: push ingested odds to your sports-betting-website API (POST /api/odds-storage/store)
# Set to your API base URL, e.g. http://localhost:3001
PUSH_TO_API_URL=

# Optional: push to central terminal (for VPS → terminal flow). Terminal merges and broadcasts to website.
# TERMINAL_URL=https://your-terminal.railway.app
# SOURCE_ID=vps1
# If terminal sets TERMINAL_INGEST_SECRET, set the same value here so POST /ingest succeeds.
# TERMINAL_INGEST_SECRET=

# Optional: persistent file for Bovada League Watcher catalog (all leagues ever seen; survives restarts).
# Default: .league-watcher-cache.json in the process working directory.
# LEAGUE_WATCHER_CACHE_PATH=/path/to/league-watcher-cache.json

# Optional: API key or auth header if your /store endpoint requires it
# PUSH_API_KEY=

# Optional: terminal login password. If set, / and the WebSocket require a simple password gate.
# TERMINAL_LOGIN_PASSWORD=changeme
