# OddsLocker Engine — copy to .env and fill in
PORT=3100

# Poll cadence (all batches fire together each session)
POLL_INTERVAL_MS=5000

# Auto-run sync sessions (can also toggle from UI)
AUTO_POLL=false

# Optional: push finished snapshot to your website
WEBHOOK_URL=
WEBHOOK_SECRET=

# Book configs — same env keys as the legacy scraper (see repo root .env)
# SPORTSBOOK_POLL_URL=...
# FANDUEL_POLL_URL=...
# BOVADA_POLL_URL=...
# etc.

# Optional login for the control UI
ENGINE_LOGIN_PASSWORD=
