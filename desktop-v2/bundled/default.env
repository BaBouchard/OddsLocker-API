# OddsLocker Scraper bundled configuration v1.2.4
# Source: .env (repo root)
# Setup wizard merges SOURCE_ID, TERMINAL_URL, and TERMINAL_INGEST_SECRET on first run.
LEAGUE_KEY=betrivers_live
SPORTSBOOK_WS_URL=
SPORTSBOOK_NAME=BetRivers
SPORTSBOOK_POLL_URL=https://eu1.offering-api.kambicdn.com/offering/v2018/rsiusny/event/live/open.json?lang=en_US&market=US-NY&client_id=200&channel_id=1
SPORTSBOOK_BET_TEMPLATE_URL=https://eu1.offering-api.kambicdn.com/offering/v2018/rsiusny/betoffer/event/{eventId}.json?lang=en_US&market=US-NY&client_id=200&channel_id=1&includeParticipants=true
SPORTSBOOK_SCRAPE_URL=
POLL_INTERVAL_MS=5000
WS_SERVER_PORT=8765
PUSH_TO_API_URL=
TERMINAL_URL=https://oddslocker-api-production.up.railway.app
SOURCE_ID=scraper1

# FanDuel in-play API (enables FanDuel checkbox + odds)
FANDUEL_POLL_URL=https://api.sportsbook.fanduel.com/sbapi/in-play?timezone=America%2FNew_York&eventTypeId=7522&includeTabs=true&_ak=FhMFpcPWXMeyZxOx
FANDUEL_NAME=FanDuel
# Must match your state. Copy from Request Headers: X-Sportsbook-Region (e.g. NJ, NY, PA).
FANDUEL_REGION=NJ
# Referer/Origin so API returns JSON (must match the site you use, e.g. sportsbook.fanduel.com/live).
FANDUEL_ORIGIN=https://sportsbook.fanduel.com
# Set to 1 to save each FanDuel API response to debug-fanduel-response.json (for fixing the parser).
DEBUG_FANDUEL=1

# Bovada live sportsbook
BOVADA_POLL_URL=https://www.bovada.lv/services/sports/event/coupon/events/A/description/?selectedPaths=227,240,239,2100,237,226,1201,215,1,238,22881,22888,6000,1900,1206,22889,5000,1200,22877,22878,22886,22884,22883,3300,2700,3000,3700,1202,7000,8000&marketFilterId=def&liveOnly=true&lnGrp=2&lang=en

